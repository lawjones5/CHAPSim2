"","url":"module/util_mod.html"},{"title":"input_general_mod – Fortran Program","text":"Read and validate the main CHAPSim input file. This module owns the user-facing input_chapsim.ini interpretation: process\nswitches, geometry, mesh, flow, thermal, MHD, boundary-condition, scheme, I/O,\nand statistics settings. It also prints readable names for selected integer\nIDs so run logs are easier to audit. Uses print_msg_mod parameters_constant_mod Variables Type Visibility Attributes Name Initial logical, public :: is_prerun logical, public :: is_postprocess Functions public  function get_name_drivenforce (ifl) result(str) Arguments Type Intent Optional Attributes Name integer, intent(in) :: ifl Return Value character(len=72) Subroutines public  subroutine Read_input_parameters () Reading the input parameters from the given file.\nScope:  mpi    called-freq    xdomain\n        all    once           all\n- none (in): NA\n- none (out): NA\nRead, validate, and distribute all input parameters. Read more… Arguments None","tags":"","url":"module/input_general_mod.html"},{"title":"apx_prerun_mod – Fortran Program","text":"Approximate pre-run estimates for DNS mesh and time-step suitability. The routines in this module provide empirical checks for wall-bounded cases,\nincluding approximate skin-friction estimates, wall-unit spacing, Hartmann\nlayer spacing, and CFL-related time-step guidance. Uses math_mod parameters_constant_mod input_general_mod mpi_mod wtformat_mod Variables Type Visibility Attributes Name Initial real(kind=WP), public, parameter :: dxplus_max = 10.0_WP real(kind=WP), public, parameter :: dzplus_max = 5.0_WP real(kind=WP), public, parameter :: dyplus_max = 1.0_WP real(kind=WP), public, parameter :: Cflmax = 0.714_WP real(kind=WP), public, parameter :: Ctmmax = 0.1_WP real(kind=WP), public, save :: dymax real(kind=WP), public, save :: dymin real(kind=WP), public, save :: rmin real(kind=WP), public, save :: rmax real(kind=WP), public, save :: Re_tau real(kind=WP), public, save :: u_tau Subroutines public  subroutine estimate_spacial_resolution (fl, dm, opt_mh) Estimate whether the current mesh is adequate for wall-bounded DNS.\n- fl (in): Flow configuration.\n- dm (in): Domain and mesh descriptor.\n- opt_mh (in): Optional MHD configuration for Hartmann-layer checks. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(in) :: fl type( t_domain ), intent(in) :: dm type( t_mhd ), intent(in), optional :: opt_mh public  subroutine estimate_temporal_resolution (fl, dm) Estimate time-step and CFL suitability before a production run.\n- fl (in): Flow configuration.\n- dm (in): Domain and mesh descriptor. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(in) :: fl type( t_domain ), intent(in) :: dm","tags":"","url":"module/apx_prerun_mod.html"},{"title":"bc_convective_outlet_mod – Fortran Program","text":"Uses decomp_2d parameters_constant_mod udf_type_mod Subroutines public  subroutine compute_convective_outlet_flow (fl, dm, isub) Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_domain ), intent(inout) :: dm integer, intent(in) :: isub public  subroutine correct_convective_outlet_flow (fl, dm, isub) Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_domain ), intent(inout) :: dm integer, intent(in) :: isub public  subroutine update_fbcx_convective_outlet_thermo (tm, dm, isub) Arguments Type Intent Optional Attributes Name type( t_thermo ), intent(inout) :: tm type( t_domain ), intent(inout) :: dm integer, intent(in) :: isub public  subroutine update_fbcz_convective_outlet_thermo (tm, dm, isub) call enforce_domain_energy_balance_dyn_fbc(fl, dm) ! todo-check necessary? Arguments Type Intent Optional Attributes Name type( t_thermo ), intent(inout) :: tm type( t_domain ), intent(inout) :: dm integer, intent(in) :: isub public  subroutine compute_convective_outlet_thermo (tm, dm, isub) Arguments Type Intent Optional Attributes Name type( t_thermo ), intent(inout) :: tm type( t_domain ), intent(inout) :: dm integer, intent(in) :: isub","tags":"","url":"module/bc_convective_outlet_mod.html"},{"title":"operations – Fortran Program","text":"Source file operations.f90. A general operation of derivative and interpolation in 1D. Uses precision_mod parameters_constant_mod print_msg_mod Variables Type Visibility Attributes Name Initial real(kind=WP), public, save :: d1fC2C (NL,NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: d1rC2C (NL,2*NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: d1fP2P (NL,NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: d1rP2P (NL,2*NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: d1fC2P (NL,NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: d1rC2P (NL,2*NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: d1fP2C (NL,NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: d1rP2C (NL,2*NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: m1fP2C (NL,NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: m1rP2C (NL,2*NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: m1fC2P (NL,NS,NBCS:NBCE,NACC) real(kind=WP), public, save :: m1rC2P (NL,2*NS,NBCS:NBCE,NACC) Subroutines public  subroutine Prepare_LHS_coeffs_for_operations () Preparing coefficients for TDMA calculation.\nScope:  mpi    called-freq    xdomain\n        all    once           all Arguments None public  subroutine Get_x_midp_C2P_3D (fi3d, fo3d, dm, iacc, ibc, fbc2d) To caculate the mid-point interpolation in 3D.\nScope:  mpi            called-freq    xdomain     module\n      in-given pencil    needed       specified   pubic\n- ixsub (in): x-subdomain index\n- ibc (in): bc type\n- fbc (in): bc value\n- inbr (in): the neibouring index of 4 bc nodes\n- fi (in): the input array of original variable\n- fo (out): the output array of interpolated variable Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in) :: fi3d (:,:,:) real(kind=WP), intent(out) :: fo3d (:,:,:) type( t_domain ), intent(in) :: dm integ