) :: dm public  subroutine get_fbcx_ftp_4pc (fbcx_ftp_4cc, fbcx_ftp_4pc, dm) to calculate:\n         fo = integral over x and z directions\n This is based only y-direction stretching.\n TODO: Here is 2nd order Trapezoid Method. Need to improve! Check!\n Scope:  mpi    called-freq    xdomain     module\n         all    needed         specified   pubic\n MPI :\n     default x-pencil\n     working in : y-pencil\n  (y) &#94; _ | |_____|______|\n      |_____|_____|______| > (z)\n Y: index arrangment\n      j'-1   j'-1  j'    j'+1  j'+2\n      _| . | . | . | . | . j-2   j-1   j     j+1    j+2 Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in), dimension(dm%d4cc%xsz(1), dm%d4cc%xsz(2), dm%d4cc%xsz(3)) :: fbcx_ftp_4cc real(kind=WP), intent(out), dimension(dm%d4pc%xsz(1), dm%d4pc%xsz(2), dm%d4pc%xsz(3)) :: fbcx_ftp_4pc type( t_domain ), intent(in) :: dm public  subroutine check_global_mass_balance (mass_imbalance, drhodt, dm) Arguments Type Intent Optional Attributes Name real(kind=WP), intent(out) :: mass_imbalance (8) real(kind=WP), intent(in), dimension(:,:,:) :: drhodt type( t_domain ), intent(in) :: dm public  subroutine damping_drhodt (accc_xpencil, dm) Arguments Type Intent Optional Attributes Name real(kind=WP), intent(inout) :: accc_xpencil (:,:,:) type( t_domain ), intent(in) :: dm","tags":"","url":"module/solver_tools_mod.html"},{"title":"boundary_conditions_mod – Fortran Program","text":"Boundary-condition orchestration for flow, thermo, MHD, and pipe-axis treatment. This module translates user-facing nominal boundary-condition IDs into the\ncalculation boundary conditions used by interpolation, derivative, pressure,\nand halo-update routines. It also owns the storage for flow/thermal boundary\nplanes and the special reconstruction rules used at the pipe centreline. Uses bc_dirichlet_mod bc_ndomain_interior_mod parameters_constant_mod udf_type_mod print_msg_mod Variables Type Visibility Attributes Name Initial integer, public, parameter :: A