ext":"subroutine test_poisson(dm) Uses poisson_interface_mod math_mod operations boundary_conditions_mod udf_type_mod Arguments Type Intent Optional Attributes Name type( t_domain ), intent(inout) :: dm","tags":"","url":"proc/test_poisson.html"},{"title":"profile_interpolation – Fortran Program","text":"subroutine profile_interpolation(nin, yin, uin, nout, ycase, ucase) Uses cubic_spline_interpolation precision_mod print_msg_mod Arguments Type Intent Optional Attributes Name integer, intent(in) :: nin real(kind=WP), intent(in), dimension(nin) :: yin real(kind=WP), intent(in), dimension(nin) :: uin integer, intent(in) :: nout real(kind=WP), intent(in), dimension(nout) :: ycase real(kind=WP), intent(out), dimension(nout) :: ucase","tags":"","url":"proc/profile_interpolation.html"},{"title":"initialise_chapsim – Fortran Program","text":"subroutine initialise_chapsim() Uses flow_thermo_initialiasation poisson_interface_mod code_performance_mod io_files_mod wrt_debug_field_mod thermo_info_mod solver_tools_mod boundary_conditions_mod visualisation_field_mod parameters_constant_mod apx_prerun_mod mhd_mod domain_decomposition_mod operations input_general_mod eq_momentum_mod geometry_mod mpi_mod io_field_interpolation_mod continuity_eq_mod Initialize CHAPSim before entering the time-advancement loop. This routine creates output folders, initializes MPI, reads input parameters,\nbuilds geometry and domain decomposition, prepares numerical operators,\ninitializes fields, and writes initial monitor/visualisation metadata.\ninitialisation of mpi, nrank, nproc\nreading input parameters build up geometry information, mesh size, grid spacing/spacing, stretching factor etc...\nbuild up operation coefficients for all x-subdomains Arguments None","tags":"","url":"proc/initialise_chapsim.html"},{"title":"Solve_eqs_iteration – Fortran Program","text":"subroutine Solve_eqs_iteration() Uses flow_thermo_initialiasation find_max_min_ave_mod vars_df_mod code_performance_mod io_tools_mod thermo_info_mod solver_tools_mod boundary_conditions_mod visualisation_field_mod statistics_mod typeconvert_mod mhd_mod input_general_mod io_monitor_mod eq_momentum_mod wtformat_mod eq_energy_mod mpi_mod io_restart_mod continuity_eq_mod Advance the coupled governing equations in time. This is the main solver loop. It handles restart/visualisation/statistics I/O,\nsubstep updates, CFL and mass-conservation checks, momentum/energy/MHD\nequation updates, monitor output, and graceful termination at the configured\nfinal iteration. Arguments None","tags":"","url":"proc/solve_eqs_iteration.html"},{"title":"Finalise_chapsim – Fortran Program","text":"subroutine Finalise_chapsim() Uses mpi_mod code_performance_mod Finalize CHAPSim after the solver loop. Records final timing information and finalizes MPI. Arguments None","tags":"","url":"proc/finalise_chapsim.html"},{"title":"build_up_fft2decomp_interface – Fortran Program","text":"public  subroutine build_up_fft2decomp_interface(dm) Uses parameters_constant_mod udf_type_mod operations ipinter=1 : conventional sixth-order interpolation coefficients as described in Lele 1992 <https://www.sciencedirect.com/science/article/pii/002199919290324R> _\\ ipinter=2 : optimal sixth-order interpolation coefficients designed to be as close as possible to spectral interpolators. ipinter=3 : aggressive sixth-order interpolation coefficients designed to add some numerical dissipation at small scales but they could result in spurious oscillations close to a wall.\n if(dm%iAccuracy == IACCU_CD2) then\n   ailcaix6 = ZERO\n   aicix6 = HALF\n   bicix6 = ZERO\n   cicix6 = ZERO\n   dicix6 = ZERO\n else\n   ailcaix6 = THREE * ZPONE\n   aicix6 = ONEPFIVE * HALF\n   bicix6 = ONE * ZPONE * HALF\n   cicix6 = ZERO\n   dicix6 = ZERO\n end if Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm","tags":"","url":"proc/build_up_fft2decomp_interface.html"},{"title":"decomp_2d_poisson_init – Fortran Program","text":"public  subroutine decomp_2d_poisson_init() !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! ! ! Arguments None","tags":"","url":"proc/decomp_2d_poisson_init.html"},{"title":"decomp_2d_poisson_finalize – Fortran Program","text":"public  subroutine decomp_2d_poisson_finalize() Arguments None","tags":"","url":"proc/decomp_2d_poisson_finalize.html"},{"title":"is_RK_proj – Fortran Program","text":"public pure function is_RK_proj(isub) result(d) Uses parameters_constant_mod Arguments Type Intent Optional Attributes Name integer, intent(in) :: isub Return Value logical","tags":"","url":"proc/is_rk_proj.html"},{"title":"Update_Re – Fortran Program","text":"public  subroutine Update_Re(iter, fl) Uses parameters_constant_mod udf_type_mod thermo_info_mod The main code for initialising flow variables\nThis subroutine is called once in initialise_chapsim. Arguments Type Intent Optional Attributes Name integer, intent(in) :: iter type( t_flow ), intent(inout) :: fl","tags":"","url":"proc/update_re.html"},{"title":"Update_PrGr – Fortran Program","text":"public  subroutine Update_PrGr(fl, tm) Uses parameters_constant_mod udf_type_mod thermo_info_mod Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_thermo ), intent(inout) :: tm","tags":"","url":"proc/update_prgr.html"},{"title":"Calculate_vis_sponge – Fortran Program","text":"public  subroutine Calculate_vis_sponge(fl, dm) Uses parameters_constant_mod math_mod udf_type_mod thermo_info_mod Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_domain ), intent(in) :: dm","tags":"","url":"proc/calculate_vis_sponge.html"},{"title":"Adjust_to_xzmean_zero – Fortran Program","text":"public  subroutine Adjust_to_xzmean_zero(var, dtmp, n, varxz) Uses io_files_mod udf_type_mod mpi_mod The main code for initialising flow variables not changing storage position, exclude b.c. values, for example, developing\nflow.\nMPI : x-pencil\n (y) &#94; _ | |_____|______|\n     |_____|_____|______| > (z)\n- none (inout): NA\n (y) &#94; _ | |_____|______|\n     |_____|_____|______| > (z) Arguments Type Intent Optional Attributes Name real(kind=WP), intent(inout), dimension(dtmp%xsz(1), dtmp%xsz(2), dtmp%xsz(3)) :: var type(DECOMP_INFO), intent(in) :: dtmp integer, intent(in) :: n real(kind=WP), intent(in), dimension(n) :: varxz","tags":"","url":"proc/adjust_to_xzmean_zero.html"},{"title":"Check_cfl_diffusion – Fortran Program","text":"public  subroutine Check_cfl_diffusion(fl, dm, opt_tm) Uses parameters_constant_mod udf_type_mod print_msg_mod mpi_mod wtformat_mod (y) &#94; _ | |_____|______|\n    |_____|_____|______| > (z) Arguments Type Intent Optional Attributes Name type( t_flow ), intent(in) :: fl type( t_domain ), intent(in) :: dm type( t_thermo ), intent(in), optional :: opt_tm","tags":"","url":"proc/check_cfl_diffusion.html"},{"title":"Check_cfl_convection – Fortran Program","text":"public  subroutine Check_cfl_convection(u, v, w, dm) Uses math_mod operations find_max_min_ave_mod parameters_constant_mod udf_type_mod decomp_2d wtformat_mod to check CFL for convection terms\nCFL = u&#94;x/dx + v&#94;y/dy + w&#94;z/dz < limit\nMPI : x-pencil\n (y) &#94; _ | |_____|______|\n     |_____|_____|______| > (z) Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in), dimension(dm%dpcc%xsz(1), dm%dpcc%xsz(2), dm%dpcc%xsz(3)) :: u real(kind=WP), intent(in), dimension(dm%dcpc%xsz(1), dm%dcpc%xsz(2), dm%dcpc%xsz(3)) :: v real(kind=WP), intent(in), dimension(dm%dccp%xsz(1), dm%dccp%xsz(2), dm%dccp%xsz(3)) :: w type( t_domain ), intent(inout) :: dm","tags":"","url":"proc/check_cfl_convection.html"},{"title":"get_fbcx_ftp_4pc – Fortran Program","text":"public  subroutine get_fbcx_ftp_4pc(fbcx_ftp_4cc, fbcx_ftp_4pc, dm) Uses print_msg_mod parameters_constant_mod udf_type_mod operations to calculate:\n         fo = integral over x and z directions\n This is based only y-direction stretching.\n TODO: Here is 2nd order Trapezoid Method. Need to improve! Check!\n Scope:  mpi    called-freq    xdomain     module\n         all    needed         specified   pubic\n MPI :\n     default x-pencil\n     working in : y-pencil\n  (y) &#94; _ | |_____|______|\n      |_____|_____|______| > (z)\n Y: index arrangment\n      j'-1   j'-1  j'    j'+1  j'+2\n      _| . | . | . | . | . j-2   j-1   j     j+1    j+2 Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in), dimension(dm%d4cc%xsz(1), dm%d4cc%xsz(2), dm%d4cc%xsz(3)) :: fbcx_ftp_4cc real(kind=WP), intent(out), dimension(dm%d4pc%xsz(1), dm%d4pc%xsz(2), dm%d4pc%xsz(3)) :: fbcx_ftp_4pc type( t_domain ), intent(in) :: dm","tags":"","url":"proc/get_fbcx_ftp_4pc.html"},{"title":"check_global_mass_balance – Fortran Program","text":"public  subroutine check_global_mass_balance(mass_imbalance, drhodt, dm) Uses find_max_min_ave_mod parameters_constant_mod udf_type_mod Arguments Type Intent Optional Attributes Name real(kind=WP), intent(out) :: mass_imbalance (8) real(kind=WP), intent(in), dimension(:,:,:) :: drhodt type( t_domain ), intent(in) :: dm","tags":"","url":"proc/check_global_mass_balance.html"},{"title":"damping_drhodt – Fortran Program","text":"public  subroutine damping_drhodt(accc_xpencil, dm) Uses transpose_extended_mod parameters_constant_mod udf_type_mod Arguments Type Intent Optional Attributes Name real(kind=WP), intent(inout) :: accc_xpencil (:,:,:) type( t_domain ), intent(in) :: dm","tags":"","url":"proc/damping_drhodt.html"},{"title":"config_calc_basic_ibc – Fortran Program","text":"public  subroutine config_calc_basic_ibc(dm) Uses wtformat_mod Configure basic field boundary conditions from the user input. Applies symmetry corrections, converts nominal IDs to calculation IDs, and\nstores the resulting velocity, pressure, temperature, and thermal-property\nboundary-condition arrays in the domain object.\n- dm (inout): Domain descriptor containing nominal and calculation BCs. Arguments Type Intent Optional Attributes Name type( t_domain ), intent(inout) :: dm","tags":"","url":"proc/config_calc_basic_ibc.html"},{"title":"allocate_fbc_flow – Fortran Program","text":"public  subroutine allocate_fbc_flow(dm) Allocate flow boundary-condition storage for all active domain faces.\n- dm (inout): Domain descriptor receiving face-boundary arrays. Arguments Type Intent Optional Attributes Name type( t_domain ), intent(inout) :: dm","tags":"","url":"proc/allocate_fbc_flow.html"},{"title":"allocate_fbc_thermo – Fortran Program","text":"public  subroutine allocate_fbc_thermo(dm) Allocate thermal boundary-condition storage for all active domain faces.\n- dm (inout): Domain descriptor receiving thermal face-boundary arrays. Arguments Type Intent Optional Attributes Name type( t_domain ), intent(inout) :: dm","tags":"","url":"proc/allocate_fbc_thermo.html"},{"title":"update_fbcy_cc_flow_halo – Fortran Program","text":"public  subroutine update_fbcy_cc_flow_halo(fl, dm) Uses find_max_min_ave_mod cylindrical_rn_mod Update pipe-axis halo values for flow variables stored around the y-axis centreline.\n- fl (inout): Flow variables whose cylindrical-axis halos are reconstructed.\n- dm (in): Domain and symmetry metadata for the pipe axis. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_domain ), intent(inout) :: dm","tags":"","url":"proc/update_fbcy_cc_flow_halo.html"},{"title":"update_fbcy_cc_thermo_halo – Fortran Program","text":"public  subroutine update_fbcy_cc_thermo_halo(tm, dm) Uses find_max_min_ave_mod thermo_info_mod Update pipe-axis halo values for thermal variables.\n- tm (inout): Thermal variables whose cylindrical-axis halos are reconstructed.\n- dm (in): Domain and symmetry metadata for the pipe axis. Arguments Type Intent Optional Attributes Name type( t_thermo ), intent(inout) :: tm type( t_domain ), intent(inout) :: dm","tags":"","url":"proc/update_fbcy_cc_thermo_halo.html"},{"title":"update_fbcy_cc_mhd_halo – Fortran Program","text":"public  subroutine update_fbcy_cc_mhd_halo(mh, dm) Update pipe-axis halo values for MHD variables.\n- mh (inout): MHD variables whose cylindrical-axis halos are reconstructed.\n- dm (in): Domain and symmetry metadata for the pipe axis. Arguments Type Intent Optional Attributes Name type( t_mhd ), intent(inout) :: mh type( t_domain ), intent(in) :: dm","tags":"","url":"proc/update_fbcy_cc_mhd_halo.html"},{"title":"axis_mirror_fbcy – Fortran Program","text":"public  subroutine axis_mirror_fbcy(var, pencil, fbcy, ksym, dtmp, is_odd, axis_mode, assign_axis_to_var, nr, opt_r, opt_dz, axis_rn_mode) Uses cylindrical_rn_mod math_mod Reconstruct or mirror a cylindrical field across the pipe centreline. The reconstruction mode encodes the regular Fourier content expected at the\naxis: zero, first azimuthal mode, axisymmetric mode, or mixed axisymmetric\nand second-mode content.\n- var (inout): Field to mirror or reconstruct near the axis.\n- pencil (in): Pencil orientation of var .\n- fbcy (inout): Boundary plane storage associated with the y direction.\n- ksym (in): Symmetric azimuthal-index map.\n- dtmp (in): Decomposition descriptor for var .\n- is_odd (in): Select odd or even parity.\n- axis_mode (in): Centreline reconstruction mode.\n- assign_axis_to_var (in): If true, write reconstructed axis values into var .\n- nr (in): Radial index used for axis reconstruction. Arguments Type Intent Optional Attributes Name real(kind=WP), intent(inout) :: var (:,:,:) integer, intent(in) :: pencil real(kind=WP), intent(inout) :: fbcy (:,:,:) integer, intent(in) :: ksym (:) type(DECOMP_INFO), intent(in) :: dtmp logical, intent(in), optional :: is_odd integer, intent(in), optional :: axis_mode logical, intent(in), optional :: assign_axis_to_var integer, intent(in), optional :: nr real(kind=WP), intent(in), optional :: opt_r (:) real(kind=WP), intent(in), optional :: opt_dz integer, intent(in), optional :: axis_rn_mode","tags":"","url":"proc/axis_mirror_fbcy.html"},{"title":"build_bc_symm_operation – Fortran Program","text":"public  subroutine build_bc_symm_operation(ibc, mbc, jbc) Build symmetry-operation metadata for a pair of boundary-condition IDs.\n- ibc (in): Boundary-condition IDs at the two sides of a direction.\n- mbc (out): Symmetry multiplier or mode information.\n- jbc (out): Boundary index relation used by derivative/interpolation kernels. Arguments Type Intent Optional Attributes Name integer, intent(in) :: ibc (2) integer, intent(out) :: mbc (2,3) integer, intent(in), optional :: jbc (2)","tags":"","url":"proc/build_bc_symm_operation.html"},{"title":"config_calc_eqs_ibc – Fortran Program","text":"public  subroutine config_calc_eqs_ibc(dm) Uses wtformat_mod Configure equation-specific boundary-condition helper arrays. Prepares the boundary-condition metadata used by convective, diffusive,\ncovariant, and stress-related operations after the basic BC tables are set.\n- dm (inout): Domain descriptor receiving equation-specific BC metadata. Arguments Type Intent Optional Attributes Name type( t_domain ), intent(inout) :: dm","tags":"","url":"proc/config_calc_eqs_ibc.html"},{"title":"get_fbcx_iTh – Fortran Program","text":"public  subroutine get_fbcx_iTh(ibc, dm, fbc, tm, opt_k) Uses parameters_constant_mod udf_type_mod thermo_info_mod Fill x-face thermal boundary values from the thermal state.\n- ibc (in): Boundary-condition IDs for the x faces.\n- dm (in): Domain descriptor.\n- fbc (out): Face-boundary thermal values.\n- tm (in): Thermal state. Arguments Type Intent Optional Attributes Name integer, intent(in) :: ibc (2) type( t_domain ), intent(in) :: dm real(kind=WP), intent(out) :: fbc (4,dm%dpcc%xsz(2),dm%dpcc%xsz(3)) type( t_thermo ), intent(in) :: tm real(kind=WP), intent(in), optional :: opt_k (:,:,:)","tags":"","url":"proc/get_fbcx_ith.html"},{"title":"get_fbcy_iTh – Fortran Program","text":"public  subroutine get_fbcy_iTh(ibc, dm, fbc, tm, opt_k) Uses parameters_constant_mod udf_type_mod thermo_info_mod Fill y-face thermal boundary values from the thermal state.\n- ibc (in): Boundary-condition IDs for the y faces.\n- dm (in): Domain descriptor.\n- fbc (out): Face-boundary thermal values.\n- tm (in): Thermal state. Arguments Type Intent Optional Attributes Name integer, intent(in) :: ibc (2) type( t_domain ), intent(in) :: dm real(kind=WP), intent(out) :: fbc (dm%dcpc%ysz(1),4,dm%dcpc%ysz(3)) type( t_thermo ), intent(in) :: tm real(kind=WP), intent(in), optional :: opt_k (:,:,:)","tags":"","url":"proc/get_fbcy_ith.html"},{"title":"get_fbcz_iTh – Fortran Program","text":"public  subroutine get_fbcz_iTh(ibc, dm, fbc, tm, opt_k) Uses parameters_constant_mod udf_type_mod thermo_info_mod Fill z-face thermal boundary values from the thermal state.\n- ibc (in): Boundary-condition IDs for the z faces.\n- dm (in): Domain descriptor.\n- fbc (out): Face-boundary thermal values.\n- tm (in): Thermal state. Arguments Type Intent Optional Attributes Name integer, intent(in) :: ibc (2) type( t_domain ), intent(in) :: dm real(kind=WP), intent(out) :: fbc (dm%dccp%zsz(1),dm%dccp%zsz(2),4) type( t_thermo ), intent(in) :: tm real(kind=WP), intent(in), optional :: opt_k (:,:,:)","tags":"","url":"proc/get_fbcz_ith.html"},{"title":"Solve_momentum_eq – Fortran Program","text":"public  subroutine Solve_momentum_eq(fl, dm, isub) Uses solver_tools_mod boundary_conditions_mod eq_energy_mod find_max_min_ave_mod parameters_constant_mod udf_type_mod io_tools_mod convert_primary_conservative_mod mpi_mod bc_convective_outlet_mod typeconvert_mod io_restart_mod wtformat_mod continuity_eq_mod To update the provisional u or rho u. fl (inout): flow field dm (inout): domain isub (in): RK sub-iteration\nAdvance the momentum equations for one substep. fl (inout): Flow state. dm (inout): Domain descriptor. isub (in): Substep index. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_domain ), intent(inout) :: dm integer, intent(in) :: isub","t