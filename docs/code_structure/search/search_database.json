ep index. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_thermo ), intent(inout) :: tm type( t_domain ), intent(inout) :: dm integer, intent(in) :: isub","tags":"","url":"proc/solve_energy_eq.html"},{"title":"initialise_mhd – Fortran Program","text":"public  subroutine initialise_mhd(fl, mh, dm) Uses math_mod boundary_conditions_mod udf_type_mod print_msg_mod mpi_mod Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_mhd ), intent(inout) :: mh type( t_domain ), intent(in) :: dm","tags":"","url":"proc/initialise_mhd.html"},{"title":"compute_Lorentz_force – Fortran Program","text":"public  subroutine compute_Lorentz_force(fl, mh, dm) Uses poisson_interface_mod operations boundary_conditions_mod visualisation_field_mod udf_type_mod decomp_2d continuity_eq_mod Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_mhd ), intent(inout) :: mh type( t_domain ), intent(in) :: dm","tags":"","url":"proc/compute_lorentz_force.html"},{"title":"check_current_conservation – Fortran Program","text":"public  subroutine check_current_conservation(mh, dm) Uses find_max_min_ave_mod udf_type_mod decomp_2d wtformat_mod continuity_eq_mod Arguments Type Intent Optional Attributes Name type( t_mhd ), intent(in) :: mh type( t_domain ), intent(in) :: dm","tags":"","url":"proc/check_current_conservation.html"},{"title":"read_one_3d_array – Fortran Program","text":"public  subroutine read_one_3d_array(var, keyword, idom, iter, dtmp) Uses iso_fortran_env Arguments Type Intent Optional Attributes Name real(kind=WP), intent(out), dimension(:, :, :) :: var (dtmp%xsz(1),dtmp%xsz(2),dtmp%xsz(3)) character(len=*), intent(in) :: keyword integer, intent(in) :: idom integer, intent(in) :: iter type(DECOMP_INFO), intent(in) :: dtmp","tags":"","url":"proc/read_one_3d_array.html"},{"title":"write_one_3d_array – Fortran Program","text":"public  subroutine write_one_3d_array(var, field_name