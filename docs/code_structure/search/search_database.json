 dtmp, str, nxst0) Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in) :: var (:,:,:) real(kind=WP), intent(out) :: varmax_work type(DECOMP_INFO), intent(in) :: dtmp character(len=*), intent(in) :: str integer, intent(in), optional :: nxst0 public  subroutine Find_max_min_3d (var, opt_abs, opt_calc, opt_work, opt_name) Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in) :: var (:,:,:) character(len=3), intent(in), optional :: opt_abs character(len=4), intent(in), optional :: opt_calc real(kind=WP), intent(inout), optional :: opt_work (2) character(len=*), intent(in), optional :: opt_name public  subroutine Get_volumetric_average_3d (dm, dtmp, var, fo_work, itype, str) Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm type(DECOMP_INFO), intent(in) :: dtmp real(kind=WP), intent(in) :: var (:,:,:) real(kind=WP), intent(out) :: fo_work integer, intent(in) :: itype character(len=*), intent(in), optional :: str public  subroutine Get_area_average_2d_for_fbcx (dm, dtmp, var, fo_work, itype, str) Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm type(DECOMP_INFO), intent(in) :: dtmp real(kind=WP), intent(in) :: var (:,:,:) real(kind=WP), intent(out) :: fo_work (2) integer, intent(in) :: itype character(len=4), intent(in) :: str public  subroutine Get_area_average_2d_for_fbcz (dm, dtmp, var, fo_work, itype, str) Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm type(DECOMP_INFO), intent(in) :: dtmp real(kind=WP), intent(in) :: var (:,:,:) real(kind=WP), intent(out) :: fo_work (2) integer, intent(in) :: itype character(len=4), intent(in) :: str public  subroutine Get_area_average_2d_for_fbcy (dm, dtmp, var, fo_work, itype, str, is_rf) Note: qy = r ur, integral r ur * dtheta dx, therefore no extra r here. Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm type(DECOMP_INFO), intent(in) :: dtmp real(kind=WP), intent(in) :: var (:,:,:) real(kind=WP), intent(out) :: fo_work (2) integer, intent(in) :: itype character(len=4), intent(in) :: str logical, intent(in) :: is_rf","tags":"","url":"module/find_max_min_ave_mod.html"},{"title":"eq_energy_mod – Fortran Program","text":"Energy equation and variable-property update routines. This module advances the thermal/enthalpy equation, updates density,\nviscosity, conductivity, and related property fields, and computes density\ntime-derivative information needed by variable-property flow. Uses decomp_2d wrt_debug_field_mod operations Subroutines public  subroutine Calculate_drhodt (fl, dm, isub) Compute the density time derivative used by variable-property flow.\n- fl (inout): Flow state containing density history and derivative fields.\n- dm (in): Domain descriptor.\n- isub (in): Substep index. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_domain ), intent(in) :: dm integer, intent(in) :: isub public  subroutine Update_thermal_properties (dens, visc, tm, dm) Refresh thermal-property fields from the current thermal state.\n- dens (out): Density field.\n- visc (out): Dynamic-viscosity field.\n- tm (inout): Thermal state containing temperature and property fields.\n- dm (in): Domain descriptor. Arguments Type Intent Optional Attributes Name real(kind=WP), intent(inout), dimension( dm%dccc%xsz(1), dm%dccc%xsz(2), dm%dccc%xsz(3) ) :: dens real(kind=WP), intent(inout), dimension( dm%dccc%xsz(1), dm%dccc%xsz(2), dm%dccc%xsz(3) ) :: visc type( t_thermo ), intent(inout) :: tm type( t_domain ), intent(inout) :: dm public  subroutine Solve_energy_eq (fl, tm, dm, isub) Advance the energy equation for one substep.\n- fl (inout): Flow state coupled to thermal properties.\n- tm (inout): Thermal state.\n- dm (inout): Domain descriptor.\n- isub (in): Substep index. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_thermo ), intent(inout) :: tm type( t_domain ), intent(inout) :: dm integer, intent(in) :: isub","tags":"","url":"module/eq_energy_mod.html"},{"title":"mhd_mod – Fortran Program","text":"Uses parameters_constant_mod Subroutines public  subroutine initialise_mhd (fl, mh, dm) Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_mhd ), intent(inout) :: mh type( t_domain ), intent(in) :: dm public  subroutine compute_Lorentz_force (fl, mh, dm) Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_mhd ), intent(inout) :: mh type( t_domain ), intent(in) :: dm public  subroutine check_current_conservation (mh, dm) Arguments Type Intent Optional Attributes Name type( t_mhd ), intent(in) :: mh type( t_domain ), intent(in) :: dm","tags":"","url":"module/mhd_mod.html"},{"title":"io_tools_mod – Fortran Program","text":"Uses decomp_2d_io parameters_constant_mod udf_type_mod print_msg_mod io_files_mod Variables Type Visibility Attributes Name Initial character(len=*), public, parameter :: io_restart = \"restart-io\" character(len=*), public, parameter :: io_in2outlet = \"outlet2inlet-io\" Subroutines public  subroutine read_one_3d_array (var, keyword, idom, iter, dtmp) Arguments Type Intent Optional Attributes Name real(kind=WP), intent(out), dimension(:, :, :) :: var (dtmp%xsz(1),dtmp%xsz(2),dtmp%xsz(3)) character(len=*), intent(in) :: keyword integer, intent(in) :: idom integer, intent(in) :: iter type(DECOMP_INFO), intent(in) :: dtmp public  subroutine write_one_3d_array (var, field_name, idom, iter, dtmp, io_mode) Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in), contiguous :: var (:,:,:) character(len=*), intent(in) :: field_name integer, intent(in) :: idom integer, intent(in) :: iter type(DECOMP_INFO), intent(in) :: dtmp integer, intent(in) :: io_mode public  subroutine rename_existing_file (file_w_path) Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: file_w_path public  subroutine initialise_decomp_io (dm) Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm public  subroutine generate_pathfile_name (flname_path, dmtag, keyword, path, extension, opt_timetag, opt_flname) Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: flname_path integer, intent(in) :: dmtag character(len=*), intent(in) :: keyword character(len=*), intent(in) :: path character(len=*), intent(in) :: extension integer, intent(in), optional :: opt_timetag character(len=*), intent(inout), optional :: opt_flname","tags":"","url":"module/io_tools_mod.html"},{"title":"visualisation_xdmf_io_mod – Fortran Program","text":"Low-level XDMF writer helpers for CHAPSim visualisation output. This module writes the XML fragments that describe Cartesian rectilinear\ngrids, cylindrical curvilinear grids, scalar attributes, and binary data\nreferences for ParaView/VisIt-compatible XDMF files. Uses parameters_constant_mod iso_fortran_env Functions public pure function xdmf_dims_kji_string (nijk) result(s) Convert CHAPSim i,j,k dimensions to the XDMF k,j,i ordering.\n- nijk (in): Dimensions in solver order.\nReturn: Dimension string used by XDMF topology and attribute records. Arguments Type Intent Optional Attributes Name integer, intent(in) :: nijk (NDIM) Return Value character(len=64) Subroutines public  subroutine xdmf_begin_grid_cart (unit, grid_name, nnode, grid_files_1d) Start an XDMF rectilinear Cartesian grid.\n- unit (in): Open Fortran unit for the XDMF file.\n- grid_name (in): Name of the XDMF grid.\n- nnode (in): Node counts in solver order.\n- grid_files_1d (in): Binary coordinate files for x, y, and z. Arguments Type Intent Optional Attributes Name integer, intent(in) :: unit character(len=*), intent(in) :: grid_name integer, intent(in) :: nnode (NDIM) character(len=*), intent(in) :: grid_files_1d (NDIM) public  subroutine xdmf_begin_grid_cyl (unit, grid_name, nnode, grid_file) Start an XDMF curvilinear grid for cylindrical cases.\n- unit (in): Open Fortran unit for the XDMF file.\n- grid_name (in): Name of the XDMF grid.\n- nnode (in): Node counts in solver order.\n- grid_file (in): Binary XYZ coordinate file. Arguments Type Intent Optional Attributes Name integer, intent(in) :: unit character(len=*), intent(in) :: grid_name integer, intent(in) :: nnode (NDIM) character(len=*), intent(in) :: grid_file public  subroutine xdmf_write_attribute_scalar (unit, name, center, dims_kji, data_file_rel) Add a scalar field attribute to the current XDMF grid.\n- unit (in): Open Fortran unit for the XDMF file.\n- name (in): Attribute name shown in visualisation tools.\n- center (in): XDMF centering, typically Cell or Node .\n- dims_kji (in): Field dimensions in XDMF order.\n- data_file_rel (in): Relative binary data path referenced by the XDMF file. Arguments Type Intent Optional Attributes Name integer, intent(in) :: unit character(len=*), intent(in) :: name character(len=*), intent(in) :: center character(len=*), intent(in) :: dims_kji character(len=*), intent(in) :: data_file_rel public  subroutine xdmf_end_grid (unit) Close the current XDMF grid, domain, and document.\n- unit (in): Open Fortran unit for the XDMF file. Arguments Type Intent Optional Attributes Name integer, intent(in) :: unit","tags":"","url":"module/visualisation_xdmf_io_mod.html"},{"title":"visualisation_mesh_mod – Fortran Program","text":"Mesh-file generation for visualisation output. Writes Cartesian one-dimensional coordinate files or cylindrical XYZ grids\nand the XDMF mesh descriptors used by field-output routines. Uses io_tools_mod visualisation_xdmf_io_mod parameters_constant_mod iso_fortran_env Variables Type Visibility Attributes Name Initial integer, public, parameter :: NSLICE = 3 integer, public, parameter :: Ivisu_3D = 0 integer, public, parameter :: Ivisu_2D = 1 integer, public, parameter :: Ivisu_3D2D = 2 integer, public, save :: nave_plane (NDIM) type(DECOMP_INFO), public :: d1cc type(DECOMP_INFO), public :: dc1c type(DECOMP_INFO), public :: dcc1 integer, public, save :: slice_idx (NDIM,0:NSLICE) integer, public, save :: nnd_visu (NDIM) integer, public, save :: ncl_visu (NDIM) character(len=256), public, save :: grid_cart_3d_fl (NDIM) character(len=256), public, save :: grid_cart_slice (NDIM,NDIM,0:NSLICE) character(len=256), public, save :: grid_cyl_3d_fl character(len=256), public, save :: grid_cyl_slice (NDIM,0:NSLICE) Subroutines public  subroutine write_visu_ini (dm) Initialise visualisation mesh files and slice metadata.\n- dm (in): Domain descriptor containing mesh, decomposition, and geometry metadata. Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm","tags":"","url":"module/visualisation_mesh_mod.html"},{"title":"visualisation_field_mod – Fortran Program","text":"High-level visualisation output for flow, thermal, MHD, and generic fields. This module writes binary field data and matching XDMF descriptors for full\nthree-dimensional outputs and configured plane/slice outputs. Uses visualisation_mesh_mod io_tools_mod visualisation_xdmf_io_mod parameters_constant_mod Subroutines public  subroutine write_visu_flow (fl, dm, suffix) Write flow variables to visualisation files.\n- fl (in): Flow state.\n- dm (in): Domain descriptor.\n- suffix (in): Optional suffix appended to the visualisation file name. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(in) :: fl type( t_domain ), intent(in) :: dm character(len=*), intent(in), optional :: suffix public  subroutine write_visu_thermo (tm, fl, dm, suffix) Write thermal and variable-property fields to visualisation files.\n- tm (in): Thermal state.\n- fl (in): Flow state containing density and viscosity.\n- dm (in): Domain descriptor.\n- suffix (in): Optional suffix appended to the visualisation file name. Arguments Type Intent Optional Attributes Name type( t_thermo ), intent(in) :: tm type( t_flow ), intent(in) :: fl type( t_domain ), intent(in) :: dm character(len=*), intent(in), optional :: suffix public  subroutine write_visu_mhd (mh, fl, dm, suffix) Write MHD fields and Lorentz-force components to visualisation files.\n- mh (in): MHD state.\n- fl (in): Flow state containing Lorentz-force arrays.\n- dm (in): Domain descriptor.\n- suffix (in): Optional suffix appended to the visualisation file name. Arguments Type Intent Optional Attributes Name type( t_mhd ), intent(in) :: mh type( t_flow ), intent(in) :: fl type( t_domain ), intent(in) :: dm character(len=*), intent(in), optional :: suffix public  subroutine write_visu_any3darray (var, varname, visuname, dtmp, dm, iter) Write an arbitrary three-dimensional field using its decomposition metadata.\n- var (in): Field data.\n- varname (in): Field name used in output files.\n- visuname (in): Visualisation group/file stem.\n- dtmp (in): Decomposition descriptor for var .\n- dm (in): Domain descriptor.\n- iter (in): Iteration number used in output names. Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in) :: var (:,:,:) character(len=*), intent(in) :: varname character(len=*), intent(in) :: visuname type(DECOMP_INFO), intent(in) :: dtmp type( t_domain ), intent(in) :: dm integer, intent(in) :: iter public  subroutine write_visu_file_begin (dm, visuname, iter, opt_is_savg) Open and write the header/mesh references for a visualisation XDMF file.\n- dm (in): Domain descriptor.\n- visuname (in): Visualisation file stem.\n- iter (in): Iteration number used in output names.\n- opt_is_savg (in): Optional flag for statistics-average output. Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm character(len=*), intent(in) :: visuname integer, intent(in) :: iter logical, intent(in), optional :: opt_is_savg public  subroutine write_visu_file_end (dm, visuname, iter, opt_is_savg) Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm character(len=*), intent(in) :: visuname integer, intent(in) :: iter logical, intent(in), optional :: opt_is_savg public  subroutine write_visu_field_bin_and_xdmf (dm, field_in, field_name, visuname, iter, direction, opt_ibc) Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm real(kind=WP), intent(in) :: field_in (:,:,:) character(len=*), intent(in) :: field_name character(len=*), intent(in) :: visuname integer, intent(in) :: iter integer, intent(in) :: direction integer, intent(in), optional :: opt_ibc (:) public  subroutine write_visu_plane_binary_and_xdmf (dm, accc, field_name, visuname, dir, n, iter, io_mode) Arguments Type Intent Optional Attributes Name type( t_domain ), intent(in) :: dm real(kind=WP), intent(in) :: accc (:,:,:) character(len=*), intent(in) :: field_name character(len=*), intent(in) :: visuname integer, intent(in) :: dir integer, intent(in) :: n integer, intent(in) :: iter integer, intent(in) :: io_mode","tags":"","url":"module/visualisation_field_mod.html"},{"title":"convert_primary_conservative_mod – Fortran Program","text":"Subroutines public  subroutine convert_primary_conservative (dm, dens, itag, iloc, qx, qy, qz, gx, gy, gz) Arguments Type Intent Optional Attributes Name type( t_domain ), intent(inout) :: dm real(kind=WP), intent(in), dimension( dm%dccc%xsz(1), dm%dccc%xsz(2), dm%dccc%xsz(3)) :: dens integer, intent(in) :: itag integer, intent(in) :: iloc real(kind=WP), intent(inout), optional, dimension( dm%dpcc%xsz(1), dm%dpcc%xsz(2), dm%dpcc%xsz(3)) :: qx real(kind=WP), intent(inout), optional, dimension( dm%dcpc%xsz(1), dm%dcpc%xsz(2), dm%dcpc%xsz(3)) :: qy real(kind=WP), intent(inout), optional, dimension( dm%dccp%xsz(1), dm%dccp%xsz(2), dm%dccp%xsz(3)) :: qz real(kind=WP), intent(inout), optional, dimension( dm%dpcc%xsz(1), dm%dpcc%xsz(2), dm%dpcc%xsz(3)) :: gx real(kind=WP), intent(inout), optional, dimension( dm%dcpc%xsz(1), dm%dcpc%xsz(2), dm%dcpc%xsz(3)) :: gy real(kind=WP), intent(inout), optional, dimension( dm%dccp%xsz(1), dm%dccp%xsz(2), dm%dccp%xsz(3)) :: gz","tags":"","url":"module/convert_primary_conservative_mod.html"},{"title":"continuity_eq_mod – Fortran Program","text":"Divergence and mass-conservation diagnostics. Provides divergence operators for flow and generic vector fields, including\nsupport for staggered decompositions and element-wise mass-conservation\nchecks used by monitor and debug output. Uses decomp_2d operations Subroutines public  subroutine Get_divergence_flow (fl, div, dm) To calculate divergence of (rho * u) or divergence of (u)\n- div (out): div(q) or div(g)\n- d (in): domain\nCompute divergence of the active flow mass-flux or velocity field.\n- fl (in): Flow state containing velocity or mass-flux components.\n- div (out): Divergence field on cell centres.\n- dm (in): Domain descriptor. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(in) :: fl real(kind=WP), intent(out), dimension(dm%dccc%xsz(1), dm%dccc%xsz(2), dm%dccc%xsz(3)) :: div type( t_domain ), intent(in) :: dm public  subroutine Get_divergence_vector (ux, uy, uz, div, dm) To calculate divergence of (rho * u) or divergence of (u)\n- ux (in): ux or gx\n- uy (in): uy or gy\n- uz (in): uz or gz\n- div (out): div(u) or div(g)\n- d (in): domain\nCompute divergence of vector components on staggered layouts.\n- ux (in): x-component on x-staggered layout.\n- uy (in): y-component on y-staggered layout.\n- uz (in): z-component on z-staggered layout.\n- div (out): Divergence field on cell centres.\n- dm (in): Domain descriptor. Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in), dimension(dm%dpcc%xsz(1), dm%dpcc%xsz(2), dm%dpcc%xsz(3)) :: ux real(kind=WP), intent(in), dimension(dm%dcpc%xsz(1), dm%dcpc%xsz(2), dm%dcpc%xsz(3)) :: uy real(kind=WP), intent(in), dimension(dm%dccp%xsz(1), dm%dccp%xsz(2), dm%dccp%xsz(3)) :: uz real(kind=WP), intent(out), dimension(dm%dccc%xsz(1), dm%dccc%xsz(2), dm%dccc%xsz(3)) :: div type( t_domain ), intent(in) :: dm public  subroutine Get_divergence_vel_x2z (ux, uy, uz, div_zpencil_ggg, dm) To calculate divergence of (rho * u) or divergence of (u)\n- ux (in): ux or gx\n- uy (in): uy or gy\n- uz (in): uz or gz\n- div (out): div(u) or div(g)\n- d (in): domain Arguments Type Intent Optional Attributes Name real(kind=WP), intent(in), dimension(dm%dpcc%xsz(1), dm%dpcc%xsz(2), dm%dpcc%xsz(3)) :: ux real(kind=WP), intent(in), dimension(dm%dcpc%xsz(1), dm%dcpc%xsz(2), dm%dcpc%xsz(3)) :: uy real(kind=WP), intent(in), dimension(dm%dccp%xsz(1), dm%dccp%xsz(2), dm%dccp%xsz(3)) :: uz real(kind=WP), intent(out), dimension(dm%dccc%zst(1) : dm%dccc%zen(1), dm%dccc%zst(2) : dm%dccc%zen(2), dm%dccc%zst(3) : dm%dccc%zen(3)) :: div_zpencil_ggg type( t_domain ), intent(in) :: dm public  subroutine Check_element_mass_conservation (fl, dm, opt_isub, opt_str) To calculate divergence of (rho * u) or divergence of (u)\n- ux (in): ux or gx\n- uy (in): uy or gy\n- uz (in): uz or gz\n- div (out): div(u) or div(g)\n- d (in): domain\nCheck and report element-wise mass-conservation residuals.\n- fl (in): Flow state to check.\n- dm (in): Domain descriptor.\n- opt_isub (in): Optional substep index for diagnostics.\n- opt_str (in): Optional label appended to diagnostic messages. Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_domain ), intent(in) :: dm integer, intent(in), optional :: opt_isub character(len=*), intent(in), optional :: opt_str","tags":"","url":"module/continuity_eq_mod.html"},{"title":"eq_scalar_transport – Fortran Program","text":"Uses decomp_2d wrt_debug_field_mod operations Subroutines public  subroutine Calculate_scalar_fractional_step (rhs0, rhs1, dtmp, dm, isub) Arguments Type Intent Optional Attributes Name real(kind=WP), intent(inout), dimension(dtmp%xsz(1), dtmp%xsz(2), dtmp%xsz(3)) :: rhs0 real(kind=WP), intent(inout), dimension(dtmp%xsz(1), dtmp%xsz(2), dtmp%xsz(3)) :: rhs1 type(DECOMP_INFO), intent(in) :: dtmp type( t_domain ), intent(in) :: dm integer, intent(in) :: isub public  subroutine Solve_energy_eq (fl, tm, dm, isub) Arguments Type Intent Optional Attributes Name type( t_flow ), intent(inout) :: fl type( t_thermo ), intent(inout) :: tm type( t_domain ), intent(inout) :: dm integer, intent(in) :: isub","tags":"","url":"module/eq_scalar_transport.html"},{"title":"regression_test_mod – Fortran Program","text":"Regression-test metric container and JSON writer. Provides the compact metric set consumed by the shell regression tests and\nwrites rank-0 JSON files for comparison against reference values. Uses precision_mod Derived Types type, public :: t_metrics Scalar diagnostics used by smoke and regression tests. Components Type Visibility Attributes Name Initial real(kind=wp), public :: mass_balance real(kind=wp), public :: mass_residual (3) real(kind=wp), public :: kinetic_energy real(kind=wp), public :: bulk_velocity (3) real(kind=wp), public :: mean_dpdx real(kind=wp), public :: pressure_drop real(kind=wp), public :: bulk_massflux (3) real(kind=wp), public :: bulk_enthalpy real(kind=wp), public :: bulk_temperature Subroutines public  subroutine write_metrics_json (filename, metrics, is_thermo) Write regression metrics to a JSON file on rank 0.\n- filename (in): Output JSON file name.\n- metrics (in): Metrics to write.\n- is_thermo (in): Include thermal metrics when true. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename type( t_metrics ), intent(in) :: metrics logical, intent(in) :: is_thermo","tags":"","url":"module/regression_test_mod.html"},{"title":"io_monitor_mod – Fortran Program","text":"Monitor-history output for mass, bulk, probe, and regression diagnostics. This module writes the 3_monitor history files used to track run health and\nemits regression metrics at configured checkpoints. Uses precision_mod regression_test_mod print_msg_mod Subroutines public  subroutine write_monitor_ini (dm) Create monitor-history files and headers.\n- dm (inout): Domain descriptor containing monitor configuration. Arguments Type Intent Optional Attributes Name